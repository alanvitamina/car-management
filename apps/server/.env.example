# 数据库类型: mysql | json
DB_TYPE=json

# MySQL 连接 (DB_TYPE=mysql 时需要)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gov_car

# JWT 密钥 (生产环境必须修改，至少 32 位随机字符串)
JWT_SECRET=change-me-in-production-use-random-string

# 服务端口
PORT=8080

# 运行模式: development | production
# production 模式下禁用 x-user-id 免登录
NODE_ENV=development

# CORS 允许的前端域名，逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 飞书应用配置 (生产环境需要)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 前端地址（飞书 OAuth 回调后跳回前端）
FRONTEND_URL=http://localhost:5173
